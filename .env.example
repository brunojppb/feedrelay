# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
# Log filter directives (RUST_LOG format).
RUST_LOG=feedrelay=debug,info
# SQLite connection URL. The /data mount is provided by docker-compose.
DATABASE_URL=sqlite:///data/feedrelay.db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Bearer token required for all /trigger/* endpoints.
# Generate with: openssl rand -hex 32
SHORTCUT_TOKEN=

# ── Immich ───────────────────────────────────────────────────────────────────
# Base URL of your Immich instance.
IMMICH_BASE_URL=https://immich.example.com
# API key from Immich → Account Settings → API Keys.
IMMICH_API_KEY=
# CLIP natural-language query used for smart-search asset discovery.
IMMICH_DEFAULT_QUERY=landscape architecture nature scenery
# Maximum assets returned by a single smart-search call (candidate pool).
IMMICH_CANDIDATE_POOL_SIZE=50
# How many days back the takenAfter window extends.
IMMICH_LOOKBACK_DAYS=365
# Maximum area a single face bounding box may occupy (% of image area).
FACE_AREA_PER_FACE_PCT=3.0
# Maximum combined area of all face bounding boxes (% of image area).
FACE_AREA_TOTAL_PCT=8.0

# ── OpenAI ───────────────────────────────────────────────────────────────────
# OpenAI API key from platform.openai.com → API Keys.
OPENAI_API_KEY=
# OpenAI model used for the Responses API caption generation.
OPENAI_MODEL=gpt-5.4-mini

# ── Buffer ───────────────────────────────────────────────────────────────────
# Buffer API key from buffer.com → Account → API Access.
BUFFER_API_KEY=
# Buffer GraphQL endpoint (POST to root, no /graphql suffix).
BUFFER_GRAPHQL_URL=https://api.buffer.com
# ID of the Buffer Instagram channel to post to.
BUFFER_INSTAGRAM_CHANNEL_ID=

# ── Public URL / pending media ────────────────────────────────────────────────
# Public base URL of this service. Used to build /pic/<uuid>.jpg URLs that
# Buffer fetches when scheduling a post.
PUBLIC_BASE_URL=https://feedrelay.example.com
# How long a pending_media row lives before it is eligible for cleanup (minutes).
PENDING_MEDIA_TTL_MINUTES=60
